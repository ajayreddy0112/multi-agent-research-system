# Copy this file to .streamlit/secrets.toml for local Streamlit runs,
# or paste these key/value pairs into the "Secrets" editor in the
# Streamlit Community Cloud dashboard (Settings → Secrets).
#
# Streamlit auto-exposes every key here as an environment variable,
# so the existing `os.getenv(...)` calls in tools.py / agents.py work
# without any code changes.

MISTRAL_API_KEY = "your-mistral-key"
TAVILY_API_KEY = "your-tavily-key"

# Optional — override the default model.
# MISTRAL_MODEL = "mistral-small-2506"
